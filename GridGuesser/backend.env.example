# Copy to backend.env (secrets — do not commit). Loaded only by the backend service.

# CORS: public origin of the Next.js app (no trailing slash)
NEXT_PUBLIC_APP_URL=https://app.example.com

PORT=3001
NODE_ENV=production

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
DYNAMODB_USERS_TABLE=GridGuesser-Users
DYNAMODB_GAME_ROOMS_TABLE=GridGuesser-GameRooms
JWT_SECRET=
GOOGLE_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
GEMINI_API_KEY=

# Optional: game-room cache. Socket.IO stays single-process unless you add a Redis adapter.
REDIS_URL=
